{
  "dashboard": {
    "id": null,
    "uid": null,
    "title": "SomaBrain - Minimal",
    "tags": ["somabrain","minimal"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "panels": [
      {
        "type": "graph",
        "title": "Requests/sec",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
        "targets": [
          {"expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "req/s"}
        ]
      },
      {
        "type": "graph",
        "title": "Unbind operations",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
        "targets": [
          {"expr": "sum(somabrain_unbind_operations_total)", "legendFormat": "unbinds"}
        ]
      }
    ]
  }
}
