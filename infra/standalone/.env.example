# SomaBrain Standalone - Environment Configuration
# Copy this file to .env before starting: cp .env.example .env

# --- Security ---------------------------------------------------------------
# ALL values below marked [REQUIRED] must be set before `docker compose up`.
# They are intentionally left blank in this example file. Do not commit secrets.

# [REQUIRED] Root token for Vault initialization.
SOMABRAIN_VAULT_TOKEN=

# [REQUIRED] Password for the PostgreSQL database user 'somabrain'.
POSTGRES_PASSWORD=

# [REQUIRED] JWT signing secret to seed into Vault on first bootstrap.
SOMABRAIN_JWT_SECRET=

# [REQUIRED] Bootstrap-only secret used by `vault_init` to seed Vault.
# The running app fetches the token from Vault and does not read this value directly.
SOMABRAIN_MEMORY_HTTP_TOKEN=

# [REQUIRED] Bootstrap-only secret used by `vault_init` to seed Vault.
# The running cog container fetches it from Vault before launching supervisord.
SUPERVISOR_HTTP_PASS=

# [REQUIRED] MinIO root credentials. Must be strong, unique values.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# --- Connectivity -----------------------------------------------------------
# Host/Port for the main API service.
SOMABRAIN_HOST=0.0.0.0
SOMABRAIN_PORT=30101

# Memory Service (SFM) Access
# In standalone Docker mode, this defaults to host.docker.internal:10101
# Override only if using a custom networking setup.
# SOMABRAIN_MEMORY_HTTP_ENDPOINT=http://host.docker.internal:10101

# --- Feature Flags ----------------------------------------------------------
# Run mode: dev, staging, or production
SOMABRAIN_MODE=dev

# Workers configuration
SOMABRAIN_WORKERS=1

# External dependency flags (0=disable, 1=enable)
SOMABRAIN_REQUIRE_EXTERNAL_BACKENDS=1
SOMABRAIN_REQUIRE_MEMORY=1
SOMABRAIN_FORCE_FULL_STACK=1
